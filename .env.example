# --- Supabase ---------------------------------------------------------------
# Get these from your Supabase project at:
#   https://supabase.com/dashboard/project/<your-project>/settings/api

# Public project URL. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key. Safe to expose to the browser. RLS policies do the protection.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key. SERVER ONLY. Never expose to the browser.
# Used by seed scripts and any admin server-side work that needs to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
